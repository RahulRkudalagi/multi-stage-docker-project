# Unoptimized Dockerfile: uses full Node image, includes dev deps
FROM node:18

# Create app directory
WORKDIR /usr/src/app

# Copy package files and install all deps (including dev)
COPY app/package*.json ./
RUN npm install

# Copy app source
COPY app/ ./

# Expose port and start
EXPOSE 3000
ENV NODE_ENV=development
CMD ["node", "app.js"]
